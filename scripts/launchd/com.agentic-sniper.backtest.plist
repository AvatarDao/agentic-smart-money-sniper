<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentic-sniper.backtest</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>bash</string>
        <string>-lc</string>
        <string>export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH" &amp;&amp; /usr/bin/python3 "$HOME/.agentic-sniper/run_backtest_daily.py" &gt;&gt; "$HOME/.agentic-sniper/backtest.log" 2&gt;&amp;1</string>
    </array>

    <!-- Daily 04:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Don't fire at load — only on schedule -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/agentic-sniper-backtest.out</string>

    <key>StandardErrorPath</key>
    <string>/tmp/agentic-sniper-backtest.err</string>
</dict>
</plist>
